{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.jsx",
    "scripts/**/*.mjs",
    "tests/**/*.js",
    "tests/**/*.jsx"
  ]
}
